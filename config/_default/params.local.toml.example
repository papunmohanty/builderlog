# Local Firebase configuration template
# Copy this file to params.local.toml and fill in your actual values
# params.local.toml is ignored by git and won't be committed

[firebase]
apiKey = "YOUR_FIREBASE_API_KEY"
authDomain = "YOUR_PROJECT.firebaseapp.com"
projectId = "YOUR_PROJECT_ID"
storageBucket = "YOUR_PROJECT.firebasestorage.app"
messagingSenderId = "YOUR_MESSAGING_SENDER_ID"
appId = "YOUR_APP_ID"
databaseURL = "FIRESTORE_DATABASE_URI"